<style>
	@import url("https://fonts.googleapis.com/css2?family=Google+Sans+Flex:opsz,wght@6..144,1..1000 &display=swap");
	* {
		margin: 0;
	}
	body {
		background-color: rgb(216, 216, 216);
	}
	.flex-group {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
	}
	.cv {
		font-family: "Google Sans Flex", sans-serif;
		width: 210mm;
		height: 297mm;
		margin: 10px auto;
		background-color: #fff;
		padding: 40px;
	}
	.cv-section {
		margin-bottom: 30px;
	}
	.grid-6-cols {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		grid-template-rows: 1fr;
		grid-column-gap: 30px;
		grid-row-gap: 0;
	}

	.cl-2 {
		grid-column: 1 / 3;
	}
	.cl-4 {
		grid-column: 3 / 7;
	}
	.img-cv {
		margin-right: 15px;
		width: 140px;
		height: 140px;
		overflow: hidden;
		border-radius: 50%;
		img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
	}
	.infos-cv span:before {
		color: #5d5d5d;
	}
	.phone:before {
		content: "☎ ";
	}
	.email:before {
		content: "@ ";
	}
	.adress:before {
		content: "🏠︎ ";
	}
	.cv hr {
		margin: 3px 0 15px;
		border: 0;
		border-bottom: 1px solid #5d5d5d;
	}
	h1 {
		font-size: 36px;
		text-transform: uppercase;
		line-height: 1;
		font-weight: 200;
		margin-bottom: 10px;
	}
	h2 {
		font-size: 17px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 4px;
		line-height: 1;
	}

	ul,
	strong,
	span,
	p {
		margin: 0 0 10px;
		font-size: 13px;
		line-height: 1.3;
		display: block;
		width: 100%;
	}
	ul {
		padding-left: 0;
		list-style: none;
		margin-bottom: 0;
	}
	strong {
		text-transform: uppercase;
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 2px;
	}
	.cv-itms {
		margin-bottom: 15px;
		padding-left: 20px;
		position: relative;
		z-index: 0;
	}
	.cv-itms::after {
		content: "";
		width: 1px;
		background-color: #5d5d5d;
		height: calc(100% - 28px);
		position: absolute;
		left: 6px;
		top: 23px;
	}
	.cv-itms::before {
		content: "";
		width: 5px;
		height: 5px;
		background: #000000;
		box-shadow: 0 0 0 4px #ffffff, 0 0 0 5px #000000;
		border-radius: 50%;
		position: absolute;
		left: 4px;
		top: 7px;
	}
	span {
		color: #5d5d5d;
	}
	.cv-content {
		width: 85%;
	}
	progress {
		appearance: none;
		width: 100%;
		height: 6px;
		margin-bottom: 10px;
	}

	/* Background of the bar (the container) */
	progress::-webkit-progress-bar {
		background-color: #eee;
		border-radius: 0;
	}

	/* The actual progress value (the filled part) */
	progress::-webkit-progress-value {
		background-color: #5d5d5d;
		border-radius: 0;
	}

	/* Firefox specific */
	progress::-moz-progress-bar {
		background-color: #5d5d5d;
		border-radius: 0;
	}
</style>

