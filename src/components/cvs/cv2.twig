		margin: 40px auto;
		box-shadow: 0 0 10px #00000023;
		padding: 30px;
		font-family: Arial, Helvetica, sans-serif;
	}

	h1,
	h2 {
		margin: 0;
		font-family: Arial, Helvetica, sans-serif;
		font-weight: 700;
	}

	strong,
	span,
	p {
		font-size: 15px;
		margin: 0;
		font-family: Arial, Helvetica, sans-serif;
		font-weight: normal;
	}

	.grid-3 {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		margin-bottom: 10px;
	}

	.column-1 {
		grid-column: 1 / 2;
		text-align: right;
	}

	.column-2 {
		grid-column: 2 / 4;
		padding-left: 30px;
		text-align: left;
	}

	.s-cv-image#preview {
		width: 140px;
		height: 140px;
		overflow: hidden;
		background-image: url('../images/avatar.png');
		background-repeat: no-repeat;
		background-size: contain;
		background-position: 50%;
		background-size: 70%;
		background-color: #dbdbdb;
	}

	.s-cv-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.align-center {
		align-items: center;
	}

	.align-start {
		align-items: start;
	}

	.align-end {
		align-items: end;
	}
	ul {
		padding-left: 0;
		margin-bottom: 0;
	}
</style>

